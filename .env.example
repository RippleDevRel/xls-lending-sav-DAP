# XRPL Network — Devnet is the only network where XLS-66/65 are enabled
# at the time of writing. Swap to testnet/mainnet once the amendments activate.
XRPL_NETWORK_URL=wss://s.devnet.rippletest.net:51233/
XRPL_FAUCET_URL=https://faucet.devnet.rippletest.net/accounts

# MongoDB — required at request time only (build does not connect).
# Replace with an Atlas connection string in production.
MONGODB_URI=mongodb://localhost:27017/xls66-lending

# Public site URL — used in OpenGraph tags, sitemap, robots.txt.
# Leave unset for local development; set to the production origin on Vercel.
# Example: NEXT_PUBLIC_SITE_URL=https://xls66.example.com
NEXT_PUBLIC_SITE_URL=
